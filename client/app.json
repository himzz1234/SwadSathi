{
  "expo": {
    "scheme": "acme",
    "splash": {
      "image": "./assets/images/swadsathi.png",
      "backgroundColor": "#355e4c"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-router"
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.himzz123.canteenproject"
    }
  }
}
